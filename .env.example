# .env.example
# Copy this file to .env and fill in real values. Never commit the real .env.

# ---- Database ----
# Individual Postgres credentials, consumed by the postgres container.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=assignment_roaster

# Full SQLAlchemy connection string used directly by the backend. The
# credentials/host/db here MUST match the POSTGRES_* values above exactly —
# docker-compose's env_file does not interpolate variables within the file,
# so this string has to be kept in sync by hand whenever POSTGRES_* changes.
DATABASE_URL=postgresql://postgres:change-me-postgres-password@postgres:5432/assignment_roaster

# ---- Auth / JWT ----
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- LLM / Roast Generation ----
LLM_API_KEY=your-llm-api-key

# ---- Frontend ----
# Backend's own base URL, consumed by the frontend build and used server-side
# to construct the Google OAuth redirect_uri.
VITE_API_URL=http://localhost:8000

# Frontend origin, used by the backend for CORS allow_origins.
FRONTEND_ORIGIN=http://localhost:5173
